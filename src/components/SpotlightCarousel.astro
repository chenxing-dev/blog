---
import type { Post } from "../lib/postUtils";
import Hero from "./Hero.astro";
import FeaturedPost from "./FeaturedPost.astro";

export interface Props {
  posts: Post[];
}
const { posts } = Astro.props as Props;

// Slides: first is static hero, then featured posts
const slides = [
  { type: "hero" as const },
  ...posts.map((post) => ({
    type: "post" as const,
    post,
  })),
];
---

<section class="my-4" data-carousel>
  <div class="relative w-full overflow-hidden">
    <div
      id="carousel-slides"
      class="flex gap-4 transition-transform duration-300 ease-in-out"
    >
      {
        slides.map((slide, index) => {
          {
            if (slide.type === "hero") {
              return <Hero index={index} class="w-full shrink-0" />;
            } else if (slide.type === "post") {
              return (
                <FeaturedPost
                  index={index}
                  post={slide.post}
                  class="w-full shrink-0"
                />
              );
            }
          }
        })
      }
    </div>
    {/* Dots */}
    <div class="flex gap-2 mt-6 justify-center">
      {
        slides.map((_, i) => (
          <button
            data-dot={i}
            class="w-3 h-3 rounded-full border-3 border-black inline-block cursor-pointer"
            aria-label={`Go to slide ${i + 1}`}
          />
        ))
      }
    </div>
  </div>
</section>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const carouselSlides = document.getElementById("carousel-slides");
    const dots = document.querySelectorAll("[data-dot]");
    let activeIndex = 0;

    update();

    // Dot clicks
    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        activeIndex = Number(dot.getAttribute("data-dot"));
        update();
      });
    });

    function update() {
      if (!carouselSlides) return;

      // Move the carousel slides to show the active slide. The first slide (hero) is at 0%, subsequent slides are offset by a calculated percentage.
      carouselSlides.style.transform =
        activeIndex === 0
          ? "translateX(0)"
          : `translateX(-${(activeIndex - 1) * 50 + 25}%)`;

      // Update dots
      dots.forEach((dot) => {
        dot.classList.toggle(
          "bg-black",
          Number(dot.getAttribute("data-dot")) === activeIndex,
        );
      });
    }
  });
</script>
