---
import BaseLayout from "../layouts/Layout.astro";
import SpotlightCarousel from "../components/SpotlightCarousel.astro";
import PostGrid from "../components/PostGrid.astro";
import { getCollection } from "astro:content";
import { processPost, byDateDesc } from "../lib/postUtils";

const linuxPosts = (await getCollection("linux")).map(processPost);
const webDevPosts = (await getCollection("web")).map(processPost);
const allPosts = [...linuxPosts, ...webDevPosts].sort(byDateDesc);

// Featured posts logic: either those marked as featured or the latest 2 posts
let featuredPosts = allPosts.filter((post) => post.data.featured);
if (featuredPosts.length === 0) featuredPosts = allPosts.slice(0, 2);

const toTagKey = (tag: string) => tag.trim().toLowerCase();

const postsByTag = new Map<
  string,
  { key: string; label: string; posts: typeof allPosts }
>();

allPosts.forEach((post) => {
  (post.data.tags ?? []).forEach((label: string) => {
    const tag = toTagKey(label);
    if (!tag) return;

    let posts = postsByTag.get(tag);
    if (!posts) {
      posts = { key: tag, label, posts: [] };
      postsByTag.set(tag, posts);
    }

    if (!posts.posts.includes(post)) {
      posts.posts.push(post);
    }
  });
});

const tagFilters = [
  { key: "all", label: "All", posts: allPosts },
  ...Array.from(postsByTag.values())
    .sort((a, b) => {
      const countDiff = b.posts.length - a.posts.length;
      if (countDiff !== 0) return countDiff;
      return a.label.localeCompare(b.label, undefined, { sensitivity: "base" });
    })
    .slice(0, 16),
];
---

<BaseLayout
  title="陈刑's Tech Guides"
  description="ARCH LINUX & WEB DEV notes and guides"
  class="px-4 md:px-6"
>
  {/* Featured Posts (Carousel) */}
  <SpotlightCarousel posts={featuredPosts} />

  {/* Recent Posts (filter by tag) */}
  <section class="my-8">
    {/* Section Header with Tag Tabs */}
    <div>
      <h2 class="text-2xl font-semibold mb-2 lg:mb-4">Filter by tag</h2>
      <div class="relative w-full lg:max-w-6xl xl:max-w-7xl" data-scroll>
        <button
          type="button"
          class="hidden lg:hidden absolute -left-2 z-20 h-8 w-6 items-center justify-center bg-primary border-2 border-black shadow-[3px_3px_0_black,6px_-4px_0_white,6px_4px_0_white] text-sm font-black"
          data-scroll-arrow="left"
          aria-label="Scroll tags left"
        >
          ←
        </button>
        <button
          type="button"
          class="hidden lg:hidden absolute -right-2 z-20 h-8 w-6 items-center justify-center bg-primary border-2 border-black shadow-[3px_3px_0_black,-4px_-4px_0_white,-4px_4px_0_white] text-sm font-black"
          data-scroll-arrow="right"
          aria-label="Scroll tags right"
        >
          →
        </button>
        <div
          role="tablist"
          aria-label="Filter posts"
          data-scroll-container
          class="flex w-full flex-nowrap gap-2 items-center overflow-x-auto pb-2 px-0.5 lg:flex-wrap lg:overflow-visible lg:pb-0 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]"
        >
          {
            tagFilters.map((tagFilter, index) => (
              <button
                type="button"
                id={`tab-${tagFilter.key}`}
                role="tab"
                aria-selected={index === 0}
                aria-controls={`panel-${tagFilter.key}`}
                data-active={index === 0 ? "true" : "false"}
                data-target={tagFilter.key}
                class="relative px-2.5 py-1.5 sm:px-3 sm:py-1.5 lg:px-4 lg:py-2 text-black text-xs sm:text-sm font-bold uppercase tracking-normal sm:tracking-wide flex shrink-0 bg-white border-2 border-black shadow-neo hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none focus:outline-none data-[active=true]:translate-x-0.5 data-[active=true]:translate-y-0.5 data-[active=true]:bg-light-blue data-[active=true]:shadow-none"
              >
                {tagFilter.label}
              </button>
            ))
          }
        </div>
      </div>
    </div>
    {/* Post Grid */}
    <div class="mt-2 lg:mt-6">
      {
        tagFilters.map((filter, i) => (
          <div
            id={`panel-${filter.key}`}
            role="tabpanel"
            aria-labelledby={`tab-${filter.key}`}
            data-tag={filter.key}
            hidden={i !== 0}
          >
            <PostGrid posts={filter.posts} />
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const tabs = document.querySelectorAll(
      '[role="tab"]',
    ) as NodeListOf<HTMLElement>;
    const tabPanels = document.querySelectorAll(
      '[role="tabpanel"]',
    ) as NodeListOf<HTMLElement>;
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const target = tab.dataset.target;
        tabs.forEach((t) => {
          t.dataset.active = t === tab ? "true" : "false";
        });
        tabPanels.forEach((panel) => {
          panel.hidden = panel.dataset.tag !== target;
        });
      });
    });

    const scrollAmount = 180; // Adjust this value to control the scroll distance
    const scrollWrappers = document.querySelectorAll(
      "[data-scroll]",
    ) as NodeListOf<HTMLElement>;

    scrollWrappers.forEach((wrapper) => {
      const scroller = wrapper.querySelector(
        "[data-scroll-container]",
      ) as HTMLElement | null;
      const leftArrow = wrapper.querySelector(
        '[data-scroll-arrow="left"]',
      ) as HTMLButtonElement | null;
      const rightArrow = wrapper.querySelector(
        '[data-scroll-arrow="right"]',
      ) as HTMLButtonElement | null;

      if (!scroller || !leftArrow || !rightArrow) return;

      // Show or hide arrows based on scroll position
      const updateArrows = () => {
        const maxScroll = scroller.scrollWidth - scroller.clientWidth;
        const hasOverflow = maxScroll > 1;

        if (!hasOverflow) {
          leftArrow.classList.add("hidden");
          rightArrow.classList.add("hidden");
          return;
        }

        const atLeftEdge = scroller.scrollLeft <= 0;
        const atRightEdge = scroller.scrollLeft >= maxScroll - 1;

        leftArrow.classList.toggle("hidden", atLeftEdge);
        rightArrow.classList.toggle("hidden", atRightEdge);
      };

      updateArrows();
      scroller.addEventListener("scroll", () => updateArrows(), {
        passive: true,
      });
      window.addEventListener("resize", () => updateArrows());

      leftArrow?.addEventListener("click", () => {
        scroller.scrollBy({ left: -scrollAmount, behavior: "smooth" });
      });
      rightArrow?.addEventListener("click", () => {
        scroller.scrollBy({ left: scrollAmount, behavior: "smooth" });
      });
    });
  });
</script>
